{
  "name": "unitedops-ecs-devops-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:flight": "npm --workspace apps/flight-service run dev",
    "dev:booking": "npm --workspace apps/booking-service run dev",
    "dev:checkin": "npm --workspace apps/checkin-service run dev",
    "dev:notification": "npm --workspace apps/notification-service run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  }
}
